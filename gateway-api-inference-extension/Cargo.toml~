[package]
name = "gateway-api-inference-extension"
description = "Kubernetes Gateway API Inference Extensions bindings in Rust"
categories = ["api-bindings"]
keywords = ["kubernetes", "gateway-api","gateway-api-inference-extension"]

homepage = "https://docs.rs/crate/gateway-api/"
readme = "../README.md"
repository = "https://github.com/kubvernor/gateway-api-rs"

authors.workspace = true
edition.workspace = true
license.workspace = true
version.workspace = true

[dependencies]
delegate.workspace = true
k8s-openapi = { workspace = true, features = ["schemars"] }
kube = { workspace = true, default-features = false, features = [] }
kube-core = { workspace = true, features = ["schema"] }
kube-derive.workspace = true
once_cell.workspace = true
regex.workspace = true
schemars.workspace = true
serde_json.workspace = true
serde.workspace = true
serde_yaml.workspace = true
cfg-if.workspace = true


[package.metadata.docs.rs]
features = ["k8s-openapi/v1_33"]

[features]
default = ["standard"]
standard = []
experimental=[]



[lints.clippy]
derivable_impls = "allow"
doc_lazy_continuation = "allow"
tabs_in_doc_comments = "allow"
empty_line_after_doc_comments = "allow"
